# BlackBar Environment Variables
# Copy to ../.env and fill in values. NEVER commit .env.
# .env lives at the repo root (one level above webapp/), not inside webapp/.

# ──────────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────────
# Railway auto-injects DATABASE_URL for its managed Postgres service when
# you link the DB. For local dev, point this at a local Postgres or a
# Railway "public" connection string.
DATABASE_URL="postgresql://user:password@host:port/database"

# ──────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────
# 64+ random chars. Rotate on any suspected leak.
JWT_SECRET="generate-a-random-64-char-string"

# ──────────────────────────────────────────────
# Seed passwords (read by prisma/seed.ts)
# ──────────────────────────────────────────────
# If NODE_ENV=production, seed REFUSES to run without these set (min 8 chars).
# In development the seed falls back to a placeholder so it doesn't crash.
SEED_LANE_PASSWORD="pick-a-strong-password-for-lane"
SEED_MARIZ_PASSWORD="pick-a-strong-password-for-mariz"

# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ──────────────────────────────────────────────
# CORS
# ──────────────────────────────────────────────
# Comma-separated allowed origins. REQUIRED in production.
# Examples:
#   https://blackbar-scg-production.up.railway.app
#   https://black-bar.com
ALLOWED_ORIGINS="https://blackbar-scg-production.up.railway.app"

# ──────────────────────────────────────────────
# Anthropic — agent pipeline
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-api03-..."
