# BlackBar Environment Variables
# Copy to ../.env and fill in values (never commit .env)

# PostgreSQL — Railway provides DATABASE_URL for internal connections
DATABASE_URL="postgresql://user:password@host:port/database"

# Auth
JWT_SECRET="generate-a-random-64-char-string"
SEED_PASSWORD="choose-a-strong-password-for-initial-users"

# Server
PORT=3001
NODE_ENV=production

# CORS — comma-separated list of allowed origins (required in production)
ALLOWED_ORIGINS="https://black-bar.com"

# Anthropic — required for real agent pipeline execution
ANTHROPIC_API_KEY="sk-ant-api03-..."
