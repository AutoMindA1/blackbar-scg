{
  "compilerOptions": {
    "target": "ES2023",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023"],
    "types": ["node"],

    "outDir": "dist",
    "rootDir": ".",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,

    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noEmitOnError": false,

    "verbatimModuleSyntax": false
  },
  "include": ["server/**/*.ts"],
  "exclude": ["node_modules", "dist", "src", "**/*.deprecated"]
}
